---
const {
	title = 'Graphics Notebook',
	description = 'Satvik Gupta Blog',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0a0f17" />
		<meta name="color-scheme" content="dark" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<a class="site-mark" href="/">My Notebook</a>
				<nav aria-label="Primary" class="site-nav">
					<a href="/">Home</a>
				</nav>
			</header>
			<slot />
		</div>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #0a0f17;
		--bg-elevated: #111824;
		--surface: rgba(16, 22, 33, 0.88);
		--surface-strong: #131b28;
		--border: rgba(148, 163, 184, 0.18);
		--border-strong: rgba(148, 163, 184, 0.3);
		--text: #e6edf6;
		--text-muted: #a9b6c7;
		--accent: #9ed0ff;
		--accent-strong: #d2e6ff;
		--shadow: 0 22px 50px rgba(0, 0, 0, 0.28);
		--radius: 18px;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
	}

	body {
		background: #0a0f17;
		color: var(--text);
		font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;
		text-rendering: optimizeLegibility;
		-webkit-font-smoothing: antialiased;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	a:hover {
		color: var(--accent-strong);
	}

	img {
		max-width: 100%;
		display: block;
	}

	code,
	pre,
	kbd,
	samp {
		font-family: 'Cascadia Code', 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
	}

	.page-shell {
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1rem 0 2rem;
	}

	.site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 1rem 0 1.75rem;
	}

	.site-mark {
		font-family: 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.9rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--text);
	}

	.site-nav {
		display: flex;
		gap: 1rem;
		font-family: 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.95rem;
		color: var(--text-muted);
	}

	.site-footer {
		padding: 2rem 0 1rem;
		font-size: 0.95rem;
		color: var(--text-muted);
	}

	.site-footer p {
		margin: 0;
	}

	@media (max-width: 640px) {
		.site-header {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
