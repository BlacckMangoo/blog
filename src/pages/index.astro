---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts: any[] = await getCollection('blog');
const orderedPosts = posts
	.filter((post: any) => !post.data.draft)
	.sort((left: any, right: any) => right.data.pubDate.valueOf() - left.data.pubDate.valueOf());
---

<Layout title="Graphics Notebook" description="Notes on rendering, shaders, mathematics, and engine development.">
	<main class="home">
		<section class="hero">
			<p class="eyebrow">Rendering / Mathematics / Systems programming</p>
			<h1>Satvik Gupta's Blog</h1>
			<p class="intro">
				I love graphics programming , math and over thinking about stuff.
			</p>
		</section>

		<section class="posts">
			<div class="section-heading">
				<p>All posts</p>
			</div>
			<div class="post-list">
				{orderedPosts.map((post: any) => (
					<article class="post-row">
						<p class="post-card__date">{post.data.pubDate.toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
						<h2><a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`}>{post.data.title}</a></h2>
						<p>{post.data.description}</p>
						<ul class="tag-list" aria-label="Post tags">
							{post.data.tags.map((tag: string) => <li>{tag}</li>)}
						</ul>
					</article>
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	.home {
		padding: 1rem 0 2.5rem;
	}

	.hero {
		padding: 3rem 0 4rem;
		max-width: 72ch;
	}

	.eyebrow,
	.section-heading p,
	.post-card__date,
	.hero-links,
	.button,
	.text-link {
		font-family: 'Avenir Next', 'Segoe UI', sans-serif;
	}

	.eyebrow,
	.section-heading p {
		margin: 0 0 0.75rem;
		font-size: 0.78rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
	}

	h1 {
		margin: 0;
		font-size: clamp(3rem, 9vw, 6.2rem);
		line-height: 0.93;
		letter-spacing: -0.05em;
	}

	.intro {
		max-width: 60ch;
		margin: 1.25rem 0 0;
		font-size: 1.1rem;
		line-height: 1.85;
		color: var(--text-muted);
	}

	.hero-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		margin-top: 1.5rem;
	}

	.button,
	.text-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.8rem 1.05rem;
		border-radius: 999px;
		border: 1px solid var(--border);
	}

	.button {
		background: rgba(158, 208, 255, 0.08);
		color: var(--accent-strong);
	}

	.text-link {
		color: var(--text-muted);
	}

	.posts {
		padding: 1rem 0 0;
	}

	.section-heading {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: baseline;
		margin-bottom: 1rem;
	}

	.section-heading span {
		font-size: 0.95rem;
		color: var(--text-muted);
	}

	.post-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.post-row {
		padding: 1.15rem;
		border: 1px solid var(--border);
		border-radius: var(--radius);
		background: var(--surface);
		box-shadow: var(--shadow);
	}

	.post-row h2 {
		margin: 0.4rem 0 0;
		font-size: 1.4rem;
		line-height: 1.2;
	}

	.post-row p {
		margin: 0.8rem 0 0;
		line-height: 1.75;
		color: var(--text-muted);
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		padding: 0;
		margin: 1rem 0 0;
		list-style: none;
	}

	.tag-list li {
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		border: 1px solid rgba(148, 163, 184, 0.16);
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	@media (max-width: 720px) {
		.section-heading {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
