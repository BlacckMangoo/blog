---
const { cite } = Astro.props;
---

<blockquote class="quote">
	<div class="quote__mark">“</div>
	<div class="quote__body">
		<slot />
	</div>
	{cite && <footer class="quote__cite">{cite}</footer>}
</blockquote>

<style>
	.quote {
		margin: 1.75rem 0;
		padding: 1.1rem 1.2rem 1rem;
		border-left: 2px solid var(--accent);
		border-radius: 0 var(--radius) var(--radius) 0;
		background: linear-gradient(90deg, rgba(158, 208, 255, 0.08), rgba(255, 255, 255, 0.01));
		box-shadow: var(--shadow);
	}

	.quote__mark {
		font-size: 2rem;
		line-height: 1;
		color: var(--accent);
	}

	.quote__body :global(p) {
		margin: 0.5rem 0 0;
		font-size: 1.05rem;
		line-height: 1.75;
	}

	.quote__cite {
		margin-top: 0.75rem;
		font-family: 'Avenir Next', 'Segoe UI', sans-serif;
		font-size: 0.9rem;
		color: var(--text-muted);
	}
</style>