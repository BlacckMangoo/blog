---
import { renderToString } from 'katex';
import 'katex/dist/katex.min.css';

const { formula, block = false, class: className = '' } = Astro.props;

const html = renderToString(formula, {
	displayMode: block,
	throwOnError: false,
	strict: 'ignore',
});
---

<span class:list={["math", block && 'math--block', className]} set:html={html} />

<style>
	.math {
		font-size: 1em;
	}

	.math--block {
		display: block;
		margin: 1.2rem 0;
		overflow-x: auto;
	}
</style>